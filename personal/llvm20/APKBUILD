	sancov
	sanstats
	split-file
	verify-uselistorder
	yaml-bench
"

prepare() {
	default_prepare

	cd llvm

	# Known broken test on musl
	rm -v test/CodeGen/AArch64/wineh4.mir
	# https://github.com/llvm/llvm-project/issues/47657
	rm -v test/ExecutionEngine/Interpreter/intrinsics.ll

	# Archs that do not build the X86 target above need to
	# have llvm-debuginfo-analyzer tests disabled due to:
	# https://github.com/llvm/llvm-project/issues/106876
	if [ -n "$_llvm_targets" ]; then
		rm -v test/tools/llvm-debuginfo-analyzer/WebAssembly/01-wasm-compare-logical-elements.test \
			test/tools/llvm-debuginfo-analyzer/WebAssembly/01-wasm-select-logical-elements.test \
			test/tools/llvm-debuginfo-analyzer/WebAssembly/03-wasm-incorrect-lexical-scope-typedef.test \
			test/tools/llvm-debuginfo-analyzer/WebAssembly/04-wasm-missing-nested-enumerators.test \
			test/tools/llvm-debuginfo-analyzer/WebAssembly/05-wasm-incorrect-lexical-scope-variable.test
	fi

	case "$CARCH" in
		armv7|x86)
			rm -vf test/tools/llvm-size/radix.test
			;;
		armhf)
			rm -vf test/tools/llvm-size/radix.test \
				test/ExecutionEngine/frem.ll test/ExecutionEngine/MCJIT/frem.ll
			;;
	esac

	# package lit per llvm major
	grep -nrE '(import|from)(\s*)lit(\.|\s|$)' utils/lit utils/llvm-lit test $(find -type f -iname 'lit.site.cfg.py.in') | \
	awk -F: '{print $1}' | sort -u | xargs -r -- sed -i \
		-e "s/\(from\s*\)lit\./\1lit${_majorver}./g" \
		-e "s/\(from\s*\)lit\(\s\)/\1lit${_majorver}\2/g"
	grep -nrE 'import(\s*)lit(\.|\s|$)' utils/lit utils/llvm-lit test $(find -type f -iname 'lit.site.cfg.py.in') | \
	awk -F: '{print $1}' | sort -u | xargs -r -- sed -i \
		-e "s/\(import\s*\)lit$/\1lit${_majorver}/g" \
		-e "s/\(import\s*\)lit\./\1lit${_majorver}./g" \
		-e "s/lit\./lit${_majorver}./g"
	sed -i -e "s/\([^A-Za-z0-9]\)lit\([.\" ]\)/\1lit${_majorver}\2/g" utils/lit/setup.py
	sed -i -e "s/lit${_majorver}.cfg/lit.cfg/g" utils/lit/tests/lit.site.cfg.in
	mv utils/lit/lit.py "utils/lit/lit${_majorver}.py"
	mv utils/lit/lit    "utils/lit/lit${_majorver}"
	ln -sfv lit.cfg.py    "test/lit${_majorver}.cfg.py"
	sed -i "s/\(llvm-lit lit.py lit\)/lit${_llvmver} \1/" CMakeLists.txt  # noop?
}

build() {
	# Auto-detect it by guessing either.
	local ffi_include_dir="$(pkg-config --cflags-only-I libffi | sed 's|^-I||g')"

	# NOTE: DO NOT change CMAKE_BUILD_TYPE! Buildmodes like None will enable
	# debug assertions for LLVM!
	cmake --trace -B build -G Ninja -Wno-dev -S llvm \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_INSTALL_PREFIX=/$_prefix \
		-DCMAKE_INSTALL_RPATH=/$_prefix \
		\
		-DLLVM_DEFAULT_TARGET_TRIPLE="$CHOST" \
		-DLLVM_HOST_TRIPLE="$CHOST" \
		\
		-DFFI_INCLUDE_DIR="$ffi_include_dir" \
		-DLLVM_APPEND_VC_REV=OFF \
		-DLLVM_BINUTILS_INCDIR=/usr/include \
		-DLLVM_BUILD_DOCS=OFF \
		-DLLVM_BUILD_EXAMPLES=OFF \
		-DLLVM_BUILD_EXTERNAL_COMPILER_RT=ON \
		-DLLVM_BUILD_LLVM_DYLIB=ON \
		-DLLVM_BUILD_TESTS="$(want_check && echo ON || echo OFF)" \
		-DLLVM_ENABLE_ASSERTIONS=OFF \
		-DLLVM_ENABLE_CURL=FORCE_ON \
		-DLLVM_ENABLE_DUMP=ON \
		-DLLVM_ENABLE_EH=ON \
		-DLLVM_ENABLE_FFI=FORCE_ON \
		-DLLVM_ENABLE_LIBCXX=OFF \
		-DLLVM_ENABLE_LIBEDIT=OFF \
		-DLLVM_ENABLE_PIC=ON \
		-DLLVM_ENABLE_RTTI=ON \
		-DLLVM_ENABLE_SPHINX=OFF \
		-DLLVM_ENABLE_TERMINFO=ON \
		-DLLVM_ENABLE_ZLIB=FORCE_ON \
		-DLLVM_ENABLE_ZSTD=FORCE_ON \
		-DLLVM_INCLUDE_BENCHMARKS=OFF \
		-DLLVM_INCLUDE_EXAMPLES=OFF \
		-DLLVM_INSTALL_GTEST=ON \
		-DLLVM_INSTALL_UTILS=ON \
		-DLLVM_LINK_LLVM_DYLIB=ON \
		-DLLVM_USE_PERF=ON \
		$_llvm_targets \
		$_cmake_cross_options

	cmake --build build

	python3 llvm/utils/lit/setup.py build
}

check() {
	LD_LIBRARY_PATH="$PWD/build/lib" \
	ninja -v -C build check-llvm
}

package() {
	depends="$pkgname-linker-tools=$pkgver-r$pkgrel"
	DESTDIR="$pkgdir" cmake --install build
	python3 llvm/utils/lit/setup.py install --root="$pkgdir"

	cd "$pkgdir"/$_prefix

	# Symlink files from /usr/lib/llvm*/bin to /usr/bin.
	mkdir -p "$pkgdir"/usr/bin
	local name newname path
	for path in bin/*; do
		name=${path##*/}
		# Add version infix/suffix to the executable name.
		case "$name" in
			llvm-*) newname="llvm$_majorver-${name#llvm-}";;
			*) newname="$name$_majorver";;
		esac
		case "$name" in
			FileCheck | obj2yaml | yaml2obj) continue;;
		esac
		ln -sfv ../lib/llvm$_majorver/bin/$name "$pkgdir"/usr/bin/$newname
	done

	mkdir -p "$pkgdir"/usr/include "$pkgdir"/usr/lib/cmake

	# symlink include to /usr/include/llvm$_llvmver
	ln -sfv ../lib/$pkgname/include "$pkgdir"/usr/include/$pkgname

	# symlink cmake dir to system cmake
	ln -sfv ../$pkgname/lib/cmake/llvm "$pkgdir"/usr/lib/cmake/$pkgname
}

_gtest() {
	pkgdesc="LLVM $_majorver gtest static libraries"
	depends=""

	amove \
		"$_prefix"/lib/libLLVMTesting*.a \
		"$_prefix"/lib/libllvm_gtest*.a \
		"$_prefix"/include/llvm-gmock \
		"$_prefix"/include/llvm-gtest
}

static() {
	pkgdesc="LLVM $_majorver static libraries"
	depends=""

	amove "$_prefix"/lib/*.a
}

libs() {
	pkgdesc="LLVM $_majorver runtime library"
	depends=""
	local soname="libLLVM.so.${pkgver%.*}"
	local soname2="libLLVM-$_majorver.so"

	mkdir -p "$subpkgdir"
	cd "$subpkgdir"

	# libLLVM should be in /usr/lib. This is needed for binaries that are
	# dynamically linked with libLLVM, so they can find it on default path.
	mkdir -p "$subpkgdir"/usr/lib
	mv "$pkgdir"/$_prefix/lib/$soname "$subpkgdir"/usr/lib/
	ln -sfv $soname usr/lib/$soname2

	# And also symlink it back to the LLVM prefix.
	mkdir -p $_prefix/lib
	ln -sfv ../../$soname $_prefix/lib/$soname
	ln -sfv ../../$soname $_prefix/lib/$soname2
}

linktools() {
	pkgdesc="$pkgdesc (linker plugins)"

	amove \
		$_prefix/lib/libLTO.so* \
		$_prefix/lib/LLVMgold*
}

dev() {
	default_dev
	cd "$subpkgdir"

	amove \
		$_prefix/lib \
		$_prefix/bin/llvm-config

	# also add a suffix-version variant of llvm-config, as that's what things normally check for
	mkdir -p "$subpkgdir"/usr/bin/
	ln -sfv ../lib/llvm$_majorver/bin/llvm-config "$subpkgdir"/usr/bin/llvm-config-$_majorver
}

_test_utils() {
	pkgdesc="LLVM $_majorver utilities for executing LLVM and Clang style test suites"
	depends="python3"

	local litver=$(python3 "$builddir"/llvm/utils/lit/setup.py --version 2>/dev/null \
		| sed 's/\.dev.*$//')
	test -n "$litver"
	#provides="$provides lit=$litver-r$pkgrel"

	amove \
		usr/lib/$pkgname/bin/FileCheck \
		usr/lib/$pkgname/bin/count \
		usr/lib/$pkgname/bin/not \
		usr/lib/python* \
		usr/bin/lit$_majorver

	mv -v "$subpkgdir"/usr/bin/lit$_majorver "$subpkgdir"/$_prefix/bin/lit$_majorver
	ln -sfv lit$_majorver "$subpkgdir"/$_prefix/bin/llvm-lit$_majorver

	amove usr/bin/count$_majorver usr/bin/not$_majorver
}

_default_pkg() {
	# Symlink files from /usr/lib/llvm*/bin to /usr/bin.
	mkdir -p "$subpkgdir"/usr/bin
	local name path
	for path in $_binaries; do
		echo "handling: $path"
		name=${path##*/}
		ln -sfv ../lib/llvm$_majorver/bin/$name "$subpkgdir"/usr/bin/$name
	done
}

_default_gtest() {
	pkgdesc="LLVM default gtest static libraries"
	depends="llvm$_majorver-gtest"
	mkdir -p "${subpkgdir}/usr/include" "${subpkgdir}/usr/lib"
  for i in $(ls -1 "${pkgdir}/../${pkgname}-gtest/usr/lib/llvm${_majorver}/lib/"*.a); do
    ln -sfv "llvm${_mamjorver}/lib/${i##*/}" "${subpkgdir}/usr/lib/${i##*/}"
  done
  for i in $(ls -1 "${pkgdir}/../${pkgname}-gtest/usr/lib/llvm${_majorver}/inckude/"*); do
    ln -sfv "../lib/llvm${_mamjorver}/include/${i##*/}" "${subpkgdir}/usr/include/${i##*/}"
  done
}

_default_static() {
	pkgdesc="LLVM $_majorver static libraries"
	depends="llvm$_majorver-static"
	mkdir -p "${subpkgdir}/usr/lib"
  for i in $(ls -1 "${pkgdir}/../${pkgname}-static/usr/lib/llvm${_majorver}/lib/"*.a); do
    ln -sfv "llvm${_mamjorver}/lib/${i##*/}" "${subpkgdir}/usr/lib/${i##*/}"
  done
}

_default_linktools() {
	pkgdesc="$pkgdesc (linker plugins)"
	depends="llvm$_majorver-linker-tools"

	mkdir -p "$subpkgdir"/usr/lib/bfd-plugins/
	ln -sfv llvm$_majorver/lib/LLVMgold.so "$subpkgdir"/usr/lib/
	ln -sfv llvm$_majorver/lib/libLTO.so "$subpkgdir"/usr/lib/

	# for bfd to work with clang -flto, you need to put the linker plugin in the bfd dir too,
	# not just usr/lib.
	ln -sfv ../llvm$_majorver/lib/LLVMgold.so "$subpkgdir"/usr/lib/bfd-plugins/
}

_default_dev() {
	depends="llvm$_majorver-dev"
	mkdir -p "$subpkgdir"/usr/lib/cmake/llvm
	ln -sfv llvm$_majorver "$subpkgdir"/usr/lib/cmake/llvm
	ln -sfv llvm$_majorver/lib/LLVMgold.so "$subpkgdir"/usr/lib/
	ln -sfv llvm$_majorver/lib/libLTO.so "$subpkgdir"/usr/lib/
}

_default_test_utils() {
	pkgdesc="LLVM utilities for executing LLVM and Clang style test suites"
	depends="llvm$_majorver-test-utils"

	mkdir -p "$subpkgdir"/usr/bin/
	ln -sfv /usr/lib/llvm$_majorver/bin/lit "$subpkgdir"/usr/bin/lit
	ln -sfv /usr/bin/count$_majorver "$subpkgdir"/usr/bin/count
	ln -sfv /usr/bin/not$_majorver "$subpkgdir"/usr/bin/not
}


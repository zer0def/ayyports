5c8765d4db98e977950d2e69f19b6698a0bac51c373a19bc03b2d9b66b32161b31f8516e5e54e945cdd00385b904081942cd45debf08a5814e4ebbc06097f5f6  pipewire-updated-bindgen.patch
283665bf8f85d3cfd43f24ade057614dd8f6a8daffb4ba5e027b3a3b51537ac50996dfc1d489c0798944a7d2859a0b535ae75b7d1b16258a9d0c853c29595c18  statx-syscall.patch
"

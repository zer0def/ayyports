# Contributor: Alex Yam <alex@alexyam.com>
# Maintainer: Natanael Copa <ncopa@alpinelinux.org>
# NOTE: Upgrade together with the whole LLVM suite.
pkgver=15.0.7
_llvmver="${pkgver%%.*}"
pkgname="wasi-compiler-rt${_llvmver}"
_wasi_sdk_ver=wasi-sdk-19
pkgrel=2
pkgdesc="WASI LLVM compiler runtime"
url="https://compiler-rt.llvm.org/"
arch="all"
options="!check" # TODO: check
license="Apache-2.0 WITH LLVM-exception"
makedepends="
	clang~$_llvmver
	clang$_llvmver
	cmake
	libxml2-dev
	llvm$_llvmver-dev
	llvm$_llvmver-static
	python3-dev
	samurai
	wasi-libc
	wasi-libcxx~$_llvmver
	zlib-dev
	"
source="https://github.com/llvm/llvm-project/releases/download/llvmorg-$pkgver/llvm-project-$pkgver.src.tar.xz
	wasi-sdk-$_wasi_sdk_ver.tar.gz::https://github.com/WebAssembly/wasi-sdk/archive/refs/tags/$_wasi_sdk_ver.tar.gz
	"
builddir="$srcdir"/llvm-project-$pkgver.src

prepare() {
	default_prepare

	mv "$srcdir"/wasi-sdk-$_wasi_sdk_ver/wasi-sdk.cmake "$builddir"
	mv "$srcdir"/wasi-sdk-$_wasi_sdk_ver/cmake/Platform cmake
}

_configure() {
	local target="$1"
	local destdir="$2"

	export CMAKE_C_COMPILER="clang-${_llvmver}" CMAKE_CXX_COMPILER="clang++-${_llvmver}" \
		CMAKE_POLICY_VERSION_MINIMUM=3.5
	cmake --trace -B "${destdir}" -G Ninja -S compiler-rt -Wno-dev \
		-DCMAKE_BUILD_TYPE=MinSizeRel \
		-DCMAKE_MODULE_PATH="$builddir"/cmake \
		-DCMAKE_TOOLCHAIN_FILE="$builddir"/wasi-sdk.cmake \
		-DCMAKE_C_COMPILER_WORKS=ON \
		-DCMAKE_CXX_COMPILER_WORKS=ON \
		-DCMAKE_C_FLAGS="$CFLAGS --target=$target" \
		-DCMAKE_CXX_FLAGS="$CXXFLAGS --target=$target" \
		-DCMAKE_ASM_COMPILER_TARGET="$target" \
		-DCMAKE_CXX_COMPILER_TARGET="$target" \
		-DCMAKE_C_COMPILER_TARGET="$target" \
		-DLLVM_DEFAULT_TARGET_TRIPLE="$target" \
		-DCOMPILER_RT_BAREMETAL_BUILD=ON \
		-DCOMPILER_RT_INCLUDE_TESTS=OFF \
		-DCOMPILER_RT_HAS_FPIC_FLAG=OFF \
		-DCOMPILER_RT_DEFAULT_TARGET_ONLY=ON \
		-DCOMPILER_RT_OS_DIR=wasi \
		-DCMAKE_AR=/usr/bin/llvm$_llvmver-ar \
		-DCMAKE_RANLIB=/usr/bin/llvm$_llvmver-ranlib \
		-DWASI_SDK_PREFIX=/usr \
		-DCMAKE_INSTALL_PREFIX=/usr/lib/llvm$_llvmver/lib/clang/$_llvmver/ \
		-DCMAKE_SYSROOT=/usr/share/wasi-sysroot
}

build() {
	export CFLAGS="$CFLAGS -fno-exceptions --sysroot=/usr/share/wasi-sysroot"
	export CXXFLAGS="$CXXFLAGS -fno-exceptions --sysroot=/usr/share/wasi-sysroot"
	export CC=clang-$_llvmver CXX=clang++-$_llvmver

	_configure wasm32-wasip1 build; cmake --build build
	#_configure wasm32-wasip1-threads build-threads; cmake --build build-threads
}

package() {
	DESTDIR="$pkgdir" cmake --install build
	#DESTDIR="$pkgdir" cmake --install build-threads

	rm -r "$pkgdir"/usr/lib/llvm$_llvmver/lib/clang/$_llvmver/include
	for _p in 1 2; do
		ln -sfv wasi "$pkgdir"/usr/lib/llvm$_llvmver/lib/clang/$_llvmver/lib/wasm32-wasip$_p
		ln -sfv wasi "$pkgdir"/usr/lib/llvm$_llvmver/lib/clang/$_llvmver/lib/wasm32-unknown-wasip$_p
	done
	ln -sfv libclang_rt.builtins-wasm32.a "$pkgdir"/usr/lib/llvm$_llvmver/lib/clang/$_llvmver/lib/wasi/libclang_rt.builtins.a
	ln -sfv libclang_rt.profile-wasm32.a "$pkgdir"/usr/lib/llvm$_llvmver/lib/clang/$_llvmver/lib/wasi/libclang_rt.profile.a
}

sha512sums="
4836d3603f32e8e54434cbfa8ef33d9d473ac5dc20ebf9c67132653c73f4524931abd1084655eaee5f20bcfcb91bcc4bbc5c4a0b603ad0c9029c556e14dc4c52  llvm-project-${pkgver}.src.tar.xz
0a501fda853033425874537e0b0ed45d72b1f1488df99e16b7c1ab46d4f496e6329f9611f67bba0f9178f05df5cfe64706c7c34dab2eaee72e5274df6d85a77a  wasi-sdk-${_wasi_sdk_ver}.tar.gz
"
